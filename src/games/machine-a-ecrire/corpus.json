    {
      "id": "mae.consigne.intro",
      "text": "Bienvenue dans la machine à écrire magique ! Écoute bien le son, puis tape-le sur les touches pour l’imprimer.",
      "voice": "denise"
    },
    {
      "id": "mae.consigne.t0",
      "text": "Écoute bien la voyelle, tape sa touche, puis appuie sur Imprimer !",
      "voice": "denise"
    },
    {
      "id": "mae.consigne.t1",
      "text": "Écoute bien la syllabe, puis écris-la avec les touches !",
      "voice": "denise"
    },
    {
      "id": "mae.consigne.t2",
      "text": "Écoute bien ! Attention : certaines touches écrivent deux lettres d’un coup.",
      "voice": "denise"
    },
    {
      "id": "mae.consigne.t3",
      "text": "Regarde l’image et écoute le mot. À toi de l’écrire en entier !",
      "voice": "denise"
    },
    {
      "id": "mae.consigne.verrouille",
      "text": "Ce palier est encore fermé. Termine d’abord le palier d’avant !",
      "voice": "denise"
    },
    {
      "id": "mae.palier.t0",
      "text": "Les voyelles !",
      "voice": "denise"
    },
    {
      "id": "mae.palier.t1",
      "text": "Les syllabes !",
      "voice": "denise"
    },
    {
      "id": "mae.palier.t2",
      "text": "Les sons magiques !",
      "voice": "denise"
    },
    {
      "id": "mae.palier.t3",
      "text": "Les mots entiers !",
      "voice": "denise"
    },
    {
      "id": "mae.reaction.tu-as-ecrit",
      "text": "Tu as écrit…",
      "voice": "eloise"
    },
    {
      "id": "mae.reaction.moi-jai-dit",
      "text": "Moi, j’ai dit…",
      "voice": "eloise"
    },
    {
      "id": "mae.reaction.revision",
      "text": "D’abord, on révise un son de la dernière fois !",
      "voice": "eloise"
    },
    {
      "id": "mae.reaction.indice",
      "text": "Regarde ! La bonne touche brille.",
      "voice": "eloise"
    }
  ]
