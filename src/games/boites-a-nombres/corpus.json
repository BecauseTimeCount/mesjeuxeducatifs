{
  "voice-default": "denise",
  "entries": [
    {
      "id": "ban.intro",
      "text": "Bienvenue à l'atelier des boîtes ! L'écureuil passe des commandes : remplis la boîte, ferme-la, et le camion l'emporte ! Choisis ton niveau, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "ban.consigne.mets",
      "text": "Mets...",
      "voice": "denise"
    },
    {
      "id": "ban.obj.noisette.une",
      "text": "une noisette dans la boîte !",
      "voice": "denise"
    },
    {
      "id": "ban.obj.noisette.des",
      "text": "noisettes dans la boîte !",
      "voice": "denise"
    },
    {
      "id": "ban.obj.fraise.une",
