    {
      "id": "hef.intro",
      "text": "Bienvenue chez Hello Friends ! Ici, on écoute l'anglais et on tape la bonne image. Écoute bien la voix anglaise, puis touche l'image qui va avec. Choisis un jeu, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "hef.consigne.greetings",
      "text": "Écoute la formule en anglais, puis tape l'image qui va avec !",
      "voice": "denise"
    },
    {
      "id": "hef.consigne.feelings",
      "text": "Écoute comment se sent le personnage, puis tape le bon visage !",
      "voice": "denise"
    },
    {
      "id": "hef.consigne.age",
      "text": "Écoute l'âge en anglais, puis tape le bon chiffre !",
      "voice": "denise"
    },
    {
      "id": "hef.consigne.colour",
      "text": "Écoute la couleur préférée en anglais, puis tape la bonne couleur !",
      "voice": "denise"
    },
    {
      "id": "hef.niveau.0",
      "text": "Salutations : Hello, Goodbye. Écoute bien et tape la bonne image !",
      "voice": "eloise"
    },
    {
      "id": "hef.niveau.1",
      "text": "Politesse : Thank you, Please, et les salutations. Tape la bonne image !",
      "voice": "eloise"
    },
    {
      "id": "hef.niveau.2",
      "text": "Les émotions en anglais : happy, sad, tired, OK. Tape le bon visage !",
      "voice": "eloise"
    },
    {
      "id": "hef.niveau.3",
      "text": "Présente-toi : ton âge et ta couleur préférée en anglais. Tape la bonne réponse !",
      "voice": "eloise"
    },
    {
      "id": "hef.bravo",
      "text": "Well done!",
      "voice": "sonia"
    },
    {
