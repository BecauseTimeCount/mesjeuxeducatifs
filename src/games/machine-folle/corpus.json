{
  "voice-default": "denise",
  "entries": [
    {
      "id": "mfo.intro",
      "text": "Bienvenue dans la machine folle ! Tape sur les rouleaux pour les faire tourner et fabrique des phrases. Choisis ton niveau, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "mfo.consigne.tourne",
      "text": "Tourne les rouleaux pour fabriquer une phrase qui existe. Quand tu es prêt, appuie sur le grand bouton : la machine lit !",
      "voice": "denise"
    },
    {
      "id": "mfo.consigne.caisse",
      "text": "Regarde bien ce qu'il y a dans la caisse ! Tourne les rouleaux pour fabriquer la bonne étiquette.",
      "voice": "denise"
    },
    {
      "id": "mfo.consigne.scene",
      "text": "Regarde bien l'image ! Tourne les rouleaux pour raconter exactement ce qui se passe.",
      "voice": "denise"
    },
    {
      "id": "mfo.lit",
      "text": "La machine lit ta phrase…",
      "voice": "denise"
    },
    {
      "id": "mfo.gag.0",
      "text": "Atchoum ! Ma machine éternue ! Ça, ça n'existe pas !",
      "voice": "henri"
    },
    {
      "id": "mfo.gag.1",
      "text": "Clong ! Un boulon vient de sauter ! Quelle drôle de phrase !",
      "voice": "henri"
    },
    {
      "id": "mfo.gag.2",
      "text": "Keuf, keuf ! La machine tousse ! Quelque chose cloche dans ta phrase !",
      "voice": "henri"
    },
    {
      "id": "mfo.gag.3",
      "text": "Bzzz, boing ! La machine fait de la fumée ! Essaie autre chose !",
      "voice": "henri"
    },
    {
      "id": "mfo.regarde",
      "text": "Regarde le rouleau qui clignote… C'est lui qu'il faut tourner !",
      "voice": "denise"
    },
    {
      "id": "mfo.indice",
      "text": "Tourne le rouleau qui brille, jusqu'à trouver le mot qui va bien !",
      "voice": "eloise"
    },
    {
      "id": "mfo.livre",
      "text": "Ta phrase entre dans le livre de la machine !",
      "voice": "eloise"
    },
    {
      "id": "mfo.niveau.0",
      "text": "Deux rouleaux : qui fait quoi ?",
      "voice": "eloise"
    },
    {
      "id": "mfo.niveau.1",
      "text": "Trois rouleaux : fabrique des phrases entières !",
      "voice": "eloise"
    },
    {
      "id": "mfo.niveau.2",
      "text": "Les étiquettes : le, la, les… trouve la bonne étiquette pour chaque caisse !",
      "voice": "eloise"
    },
    {
      "id": "mfo.niveau.3",
      "text": "Les accords : un chat dort, deux chats dorment !",
      "voice": "eloise"
    },
