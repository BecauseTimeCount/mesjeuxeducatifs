{
  "voice-default": "denise",
  "entries": [
    {
      "id": "gho.intro",
      "text": "Bienvenue dans l'atelier du Grand Horloger ! Ici, c'est toi qui fais tourner le temps : le soleil, les jours, les aiguilles ! Choisis ton niveau, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "gho.niveau.0",
      "text": "La journée : matin, midi, après-midi et soir !",
      "voice": "eloise"
    },
    {
      "id": "gho.niveau.1",
      "text": "La roue des jours : lundi, mardi... toute la semaine !",
      "voice": "eloise"
    },
    {
      "id": "gho.niveau.2",
      "text": "Les heures piles : à toi de régler la petite aiguille !",
      "voice": "eloise"
    },
    {
      "id": "gho.niveau.3",
      "text": "Heures et demies : les aiguilles, les mois et les saisons !",
      "voice": "eloise"
    },
    {
      "id": "gho.bien-joue",
      "text": "Bravo, petit horloger ! C'est exactement ça !",
      "voice": "eloise"
    },
    {
      "id": "gho.oups",
      "text": "Oh là là ! Mon horloge dit que ce n'est pas tout à fait ça !",
      "voice": "henri"
    },
    {
      "id": "gho.reessaie",
      "text": "À toi de réessayer !",
      "voice": "denise"
    },
    {
      "id": "gho.indice",
      "text": "Petit coup de pouce : regarde ce qui brille, et tape dessus !",
      "voice": "eloise"
    },
    {
      "id": "gho.valide-heure",
      "text": "Quand ton horloge est prête, appuie sur : c'est l'heure !",
      "voice": "eloise"
    },
    {
      "id": "gho.aiguille.grande",
      "text": "Pour la demie, choisis la grande aiguille et tape sur le six !",
      "voice": "eloise"
    },
    {
      "id": "gho.regarde.journee",
      "text": "Regarde le ciel ! Le bon moment clignote. C'était...",
      "voice": "denise"
    },
    {
      "id": "gho.regarde.jour",
      "text": "Regarde la roue ! Le bon jour clignote. C'était...",
      "voice": "denise"
    },
    {
      "id": "gho.regarde.heure",
      "text": "Regarde l'horloge ! Les aiguilles glissent vers la bonne heure. C'était...",
      "voice": "denise"
    },
    {
      "id": "gho.regarde.mois",
      "text": "Regarde la grande roue ! Le bon mois clignote. C'était...",
      "voice": "denise"
    },
    {
      "id": "gho.regarde.saison",
      "text": "Regarde ! La bonne saison clignote. C'était...",
      "voice": "denise"
    },
    {
      "id": "gho.moment.matin",
      "text": "le matin !",
      "voice": "denise"
    },
    {
      "id": "gho.moment.midi",
      "text": "midi !",
      "voice": "denise"
    },
    {
      "id": "gho.moment.apres-midi",
      "text": "l'après-midi !",
      "voice": "denise"
    },
    {
      "id": "gho.moment.soir",
      "text": "le soir !",
      "voice": "denise"
    },
    {
      "id": "gho.act.matin.1",
      "text": "Léo prend son petit-déjeuner. C'est le matin ! Place le soleil au matin.",
      "voice": "denise"
    },
    {
      "id": "gho.act.matin.2",
      "text": "Léo se réveille et s'étire dans son lit. C'est le matin ! Place le soleil au matin.",
      "voice": "denise"
    },
    {
      "id": "gho.act.matin.3",
      "text": "Le coq chante cocorico ! C'est le matin ! Place le soleil au matin.",
      "voice": "denise"
    },
    {
      "id": "gho.act.matin.4",
      "text": "Léo s'habille pour aller à l'école. C'est le matin ! Place le soleil au matin.",
      "voice": "denise"
    },
    {
      "id": "gho.act.matin.5",
      "text": "Léo se brosse les dents après le petit-déjeuner. C'est le matin ! Place le soleil au matin.",
      "voice": "denise"
    },
    {
      "id": "gho.act.matin.6",
      "text": "Le soleil se lève, la rosée brille sur l'herbe. C'est le matin ! Place le soleil au matin.",
      "voice": "denise"
    },
    {
      "id": "gho.act.midi.1",
      "text": "Léo mange à la cantine avec ses copains. C'est midi ! Place le soleil à midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.midi.2",
      "text": "La cloche sonne, c'est l'heure du déjeuner. C'est midi ! Place le soleil à midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.midi.3",
      "text": "Le soleil est tout en haut du ciel. C'est midi ! Place le soleil à midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.midi.4",
      "text": "Papa sert une grande assiette de purée. C'est midi ! Place le soleil à midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.midi.5",
      "text": "Léo se lave les mains avant le repas du midi. C'est midi ! Place le soleil à midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.midi.6",
      "text": "Toute la famille passe à table pour déjeuner. C'est midi ! Place le soleil à midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.apres-midi.1",
      "text": "Léo fait la sieste après le déjeuner. C'est l'après-midi ! Place le soleil à l'après-midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.apres-midi.2",
      "text": "Léo joue au ballon dans la cour de récréation. C'est l'après-midi ! Place le soleil à l'après-midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.apres-midi.3",
      "text": "Léo prend son goûter avec un jus de pomme. C'est l'après-midi ! Place le soleil à l'après-midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.apres-midi.4",
      "text": "Les parents viennent chercher les enfants à l'école. C'est l'après-midi ! Place le soleil à l'après-midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.apres-midi.5",
      "text": "Léo fait du vélo au parc avec Papi. C'est l'après-midi ! Place le soleil à l'après-midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.apres-midi.6",
      "text": "Léo dessine tranquillement à la maison après l'école. C'est l'après-midi ! Place le soleil à l'après-midi.",
      "voice": "denise"
    },
    {
      "id": "gho.act.soir.1",
      "text": "Léo prend son bain avant le dîner. C'est le soir ! Place la lune au soir.",
      "voice": "denise"
    },
    {
      "id": "gho.act.soir.2",
      "text": "Toute la famille dîne ensemble. C'est le soir ! Place la lune au soir.",
      "voice": "denise"
    },
    {
      "id": "gho.act.soir.3",
      "text": "Léo met son pyjama tout doux. C'est le soir ! Place la lune au soir.",
      "voice": "denise"
    },
    {
      "id": "gho.act.soir.4",
      "text": "Maman lit une histoire avant de dormir. C'est le soir ! Place la lune au soir.",
      "voice": "denise"
    },
    {
      "id": "gho.act.soir.5",
      "text": "Les étoiles s'allument dans le ciel. C'est le soir ! Place la lune au soir.",
      "voice": "denise"
    },
    {
      "id": "gho.act.soir.6",
      "text": "Léo fait un gros câlin et va se coucher. C'est le soir ! Place la lune au soir.",
      "voice": "denise"
    },
