{
  "voice-default": "denise",
  "entries": [
    {
      "id": "bsc.intro",
      "text": "Bienvenue au bar à schémas ! Écoute bien l'histoire, dessine-la avec des barres, puis trouve le nombre mystère. Choisis ton défi, et appuie sur Jouer !",
      "voice": "eloise"
    },
    { "id": "bsc.niveau.0", "text": "Réunir : deux parties ensemble, ça fait un tout !", "voice": "eloise" },
    { "id": "bsc.niveau.1", "text": "Gagner ou perdre : avant, et après !", "voice": "eloise" },
    { "id": "bsc.niveau.2", "text": "La partie cachée : retrouve ce qui manque !", "voice": "eloise" },
    { "id": "bsc.niveau.3", "text": "Comparer : combien de plus, combien de moins ?", "voice": "eloise" },

    { "id": "bsc.phase.modelise", "text": "À toi ! Pose chaque nombre au bon endroit du schéma.", "voice": "denise" },
    { "id": "bsc.phase.calcule", "text": "Le schéma est prêt ! Écris le nombre mystère avec les touches.", "voice": "denise" },
    { "id": "bsc.schema.bravo", "text": "Super schéma !", "voice": "eloise" },

    { "id": "bsc.place.whole", "text": "c'est tout ce qu'il y a : ça va dans la grande barre, tout en haut !", "voice": "denise" },
    { "id": "bsc.place.part", "text": "c'est juste une partie : ça va en bas, dans une petite barre !", "voice": "denise" },
    { "id": "bsc.place.start", "text": "c'est ce qu'il y a au début de l'histoire : ça va dans la barre du haut, avant la flèche !", "voice": "denise" },
    { "id": "bsc.place.change", "text": "c'est ce qui change dans l'histoire : ça va sur la flèche !", "voice": "denise" },
    { "id": "bsc.place.bar", "text": "ça dit combien il y en a : ça va sur la barre, à côté du bon personnage !", "voice": "denise" },
    { "id": "bsc.place.diff", "text": "c'est la différence entre les deux : ça va au bout, là où les barres ne sont pas pareilles !", "voice": "denise" },

    { "id": "bsc.compte.regarde", "text": "Regarde ! On remplit la barre mystère ensemble.", "voice": "denise" },
    { "id": "bsc.compte.ca-fait", "text": "Ça fait...", "voice": "denise" },
    { "id": "bsc.compte.a-toi", "text": "À toi : écris-le !", "voice": "denise" },
    { "id": "bsc.indice.place", "text": "Regarde ! L'endroit qui brille attend ton nombre.", "voice": "eloise" },
    { "id": "bsc.indice.calc", "text": "Le nombre mystère brille sur la barre : écris-le !", "voice": "eloise" },

    { "id": "bsc.t0-billes.s1", "text": "Léo a", "voice": "denise" },
    { "id": "bsc.t0-billes.s2", "text": "billes dans sa poche, et", "voice": "denise" },
    { "id": "bsc.t0-billes.s3", "text": "billes dans sa main.", "voice": "denise" },
    { "id": "bsc.t0-billes.q", "text": "Combien de billes a-t-il en tout ?", "voice": "denise" },
    { "id": "bsc.t0-billes.r1", "text": "En tout, Léo a", "voice": "denise" },
    { "id": "bsc.t0-billes.r2", "text": "billes !", "voice": "denise" },

    { "id": "bsc.t0-fraises.s1", "text": "Zoé a", "voice": "denise" },
    { "id": "bsc.t0-fraises.s2", "text": "fraises dans son panier, et", "voice": "denise" },
    { "id": "bsc.t0-fraises.s3", "text": "fraises dans son bol.", "voice": "denise" },
    { "id": "bsc.t0-fraises.q", "text": "Combien de fraises a-t-elle en tout ?", "voice": "denise" },
    { "id": "bsc.t0-fraises.r1", "text": "En tout, Zoé a", "voice": "denise" },
    { "id": "bsc.t0-fraises.r2", "text": "fraises !", "voice": "denise" },

    { "id": "bsc.t0-noisettes.s1", "text": "L'écureuil cache", "voice": "denise" },
    { "id": "bsc.t0-noisettes.s2", "text": "noisettes sous l'arbre, et", "voice": "denise" },
    { "id": "bsc.t0-noisettes.s3", "text": "noisettes dans son nid.", "voice": "denise" },
    { "id": "bsc.t0-noisettes.q", "text": "Combien de noisettes a-t-il cachées en tout ?", "voice": "denise" },
    { "id": "bsc.t0-noisettes.r1", "text": "En tout, l'écureuil a caché", "voice": "denise" },
    { "id": "bsc.t0-noisettes.r2", "text": "noisettes !", "voice": "denise" },

    { "id": "bsc.t0-coquillages.s1", "text": "Papi ramasse", "voice": "denise" },
    { "id": "bsc.t0-coquillages.s2", "text": "coquillages blancs, et", "voice": "denise" },
    { "id": "bsc.t0-coquillages.s3", "text": "coquillages roses.", "voice": "denise" },
    { "id": "bsc.t0-coquillages.q", "text": "Combien de coquillages a-t-il en tout ?", "voice": "denise" },
    { "id": "bsc.t0-coquillages.r1", "text": "En tout, Papi a", "voice": "denise" },
    { "id": "bsc.t0-coquillages.r2", "text": "coquillages !", "voice": "denise" },

    { "id": "bsc.t0-poissons.s1", "text": "Plume voit", "voice": "denise" },
    { "id": "bsc.t0-poissons.s2", "text": "poissons près du bateau, et", "voice": "denise" },
    { "id": "bsc.t0-poissons.s3", "text": "poissons près des rochers.", "voice": "denise" },
    { "id": "bsc.t0-poissons.q", "text": "Combien de poissons voit-il en tout ?", "voice": "denise" },
    { "id": "bsc.t0-poissons.r1", "text": "En tout, Plume voit", "voice": "denise" },
    { "id": "bsc.t0-poissons.r2", "text": "poissons !", "voice": "denise" },

    { "id": "bsc.t1-billes.s1", "text": "Léo a", "voice": "denise" },
    { "id": "bsc.t1-billes.s2", "text": "billes. À la récré, il en gagne", "voice": "denise" },
    { "id": "bsc.t1-billes.q", "text": "Combien de billes a-t-il maintenant ?", "voice": "denise" },
    { "id": "bsc.t1-billes.r1", "text": "Maintenant, Léo a", "voice": "denise" },
    { "id": "bsc.t1-billes.r2", "text": "billes !", "voice": "denise" },

    { "id": "bsc.t1-autocollants.s1", "text": "Zoé a", "voice": "denise" },
    { "id": "bsc.t1-autocollants.s2", "text": "autocollants. Sa copine lui en donne", "voice": "denise" },
    { "id": "bsc.t1-autocollants.q", "text": "Combien d'autocollants a-t-elle maintenant ?", "voice": "denise" },
    { "id": "bsc.t1-autocollants.r1", "text": "Maintenant, Zoé a", "voice": "denise" },
    { "id": "bsc.t1-autocollants.r2", "text": "autocollants !", "voice": "denise" },

    { "id": "bsc.t1-carottes.s1", "text": "Le lapin a", "voice": "denise" },
    { "id": "bsc.t1-carottes.s2", "text": "carottes. Il en cueille encore", "voice": "denise" },
    { "id": "bsc.t1-carottes.q", "text": "Combien de carottes a-t-il maintenant ?", "voice": "denise" },
    { "id": "bsc.t1-carottes.r1", "text": "Maintenant, le lapin a", "voice": "denise" },
    { "id": "bsc.t1-carottes.r2", "text": "carottes !", "voice": "denise" },

    { "id": "bsc.t1-graines.s1", "text": "Plume a", "voice": "denise" },
    { "id": "bsc.t1-graines.s2", "text": "graines de tournesol. Il en croque", "voice": "denise" },
    { "id": "bsc.t1-graines.q", "text": "Combien de graines lui reste-t-il ?", "voice": "denise" },
    { "id": "bsc.t1-graines.r1", "text": "Maintenant, il lui reste", "voice": "denise" },
    { "id": "bsc.t1-graines.r2", "text": "graines !", "voice": "denise" },

    { "id": "bsc.t1-ballons.s1", "text": "Papi tient", "voice": "denise" },
    { "id": "bsc.t1-ballons.s2", "text": "ballons. Et pof ! Le vent en emporte", "voice": "denise" },
    { "id": "bsc.t1-ballons.q", "text": "Combien de ballons lui reste-t-il ?", "voice": "denise" },
    { "id": "bsc.t1-ballons.r1", "text": "Maintenant, il lui reste", "voice": "denise" },
    { "id": "bsc.t1-ballons.r2", "text": "ballons !", "voice": "denise" },

    { "id": "bsc.t2-billes.s1", "text": "Léo a", "voice": "denise" },
    { "id": "bsc.t2-billes.s2", "text": "billes en tout.", "voice": "denise" },
    { "id": "bsc.t2-billes.s3", "text": "sont dans sa poche. Les autres sont cachées dans sa main.", "voice": "denise" },
    { "id": "bsc.t2-billes.q", "text": "Combien de billes sont cachées dans sa main ?", "voice": "denise" },
    { "id": "bsc.t2-billes.r1", "text": "Dans sa main, il y a", "voice": "denise" },
    { "id": "bsc.t2-billes.r2", "text": "billes !", "voice": "denise" },

    { "id": "bsc.t2-bonbons.s1", "text": "Zoé a", "voice": "denise" },
    { "id": "bsc.t2-bonbons.s2", "text": "bonbons en tout.", "voice": "denise" },
    { "id": "bsc.t2-bonbons.s3", "text": "sont à la fraise. Les autres sont au citron.", "voice": "denise" },
    { "id": "bsc.t2-bonbons.q", "text": "Combien de bonbons sont au citron ?", "voice": "denise" },
    { "id": "bsc.t2-bonbons.r1", "text": "Il y a", "voice": "denise" },
    { "id": "bsc.t2-bonbons.r2", "text": "bonbons au citron !", "voice": "denise" },

    { "id": "bsc.t2-fleurs.s1", "text": "Papi a", "voice": "denise" },
    { "id": "bsc.t2-fleurs.s2", "text": "fleurs dans son jardin.", "voice": "denise" },
    { "id": "bsc.t2-fleurs.s3", "text": "sont déjà ouvertes. Les autres sont encore fermées.", "voice": "denise" },
    { "id": "bsc.t2-fleurs.q", "text": "Combien de fleurs sont encore fermées ?", "voice": "denise" },
    { "id": "bsc.t2-fleurs.r1", "text": "Il y a", "voice": "denise" },
    { "id": "bsc.t2-fleurs.r2", "text": "fleurs encore fermées !", "voice": "denise" },

    { "id": "bsc.t2-papillons.s1", "text": "Plume compte", "voice": "denise" },
    { "id": "bsc.t2-papillons.s2", "text": "papillons en tout.", "voice": "denise" },
    { "id": "bsc.t2-papillons.s3", "text": "sont posés sur une fleur. Les autres volent.", "voice": "denise" },
    { "id": "bsc.t2-papillons.q", "text": "Combien de papillons volent ?", "voice": "denise" },
    { "id": "bsc.t2-papillons.r1", "text": "Il y a", "voice": "denise" },
    { "id": "bsc.t2-papillons.r2", "text": "papillons qui volent !", "voice": "denise" },

    { "id": "bsc.t2-noisettes.s1", "text": "L'écureuil a", "voice": "denise" },
    { "id": "bsc.t2-noisettes.s2", "text": "noisettes en tout.", "voice": "denise" },
    { "id": "bsc.t2-noisettes.s3", "text": "sont déjà croquées. Les autres sont entières.", "voice": "denise" },
    { "id": "bsc.t2-noisettes.q", "text": "Combien de noisettes sont entières ?", "voice": "denise" },
    { "id": "bsc.t2-noisettes.r1", "text": "Il y a", "voice": "denise" },
    { "id": "bsc.t2-noisettes.r2", "text": "noisettes entières !", "voice": "denise" },

    { "id": "bsc.t3-cerises.s1", "text": "Papi cueille", "voice": "denise" },
    { "id": "bsc.t3-cerises.s2", "text": "cerises. Plume en picore", "voice": "denise" },
    { "id": "bsc.t3-cerises.q", "text": "Combien de cerises Papi a-t-il de plus que Plume ?", "voice": "denise" },
    { "id": "bsc.t3-cerises.r1", "text": "Papi a", "voice": "denise" },
    { "id": "bsc.t3-cerises.r2", "text": "cerises de plus que Plume !", "voice": "denise" },

    { "id": "bsc.t3-papillons.s1", "text": "Zoé observe", "voice": "denise" },
    { "id": "bsc.t3-papillons.s2", "text": "papillons. Léo en observe", "voice": "denise" },
    { "id": "bsc.t3-papillons.q", "text": "Combien de papillons Zoé voit-elle de plus que Léo ?", "voice": "denise" },
    { "id": "bsc.t3-papillons.r1", "text": "Zoé voit", "voice": "denise" },
    { "id": "bsc.t3-papillons.r2", "text": "papillons de plus que Léo !", "voice": "denise" },

    { "id": "bsc.t3-coquillages.s1", "text": "Léo a", "voice": "denise" },
    { "id": "bsc.t3-coquillages.s2", "text": "coquillages. Il en a", "voice": "denise" },
    { "id": "bsc.t3-coquillages.s3", "text": "de plus que Zoé.", "voice": "denise" },
    { "id": "bsc.t3-coquillages.q", "text": "Combien de coquillages a Zoé ?", "voice": "denise" },
    { "id": "bsc.t3-coquillages.r1", "text": "Zoé a", "voice": "denise" },
    { "id": "bsc.t3-coquillages.r2", "text": "coquillages !", "voice": "denise" },

    { "id": "bsc.t3-fraises.s1", "text": "Le lapin a", "voice": "denise" },
    { "id": "bsc.t3-fraises.s2", "text": "fraises. Il en a", "voice": "denise" },
    { "id": "bsc.t3-fraises.s3", "text": "de plus que la tortue.", "voice": "denise" },
    { "id": "bsc.t3-fraises.q", "text": "Combien de fraises a la tortue ?", "voice": "denise" },
    { "id": "bsc.t3-fraises.r1", "text": "La tortue a", "voice": "denise" },
    { "id": "bsc.t3-fraises.r2", "text": "fraises !", "voice": "denise" },

    { "id": "bsc.t3-noisettes.s1", "text": "L'écureuil a", "voice": "denise" },
    { "id": "bsc.t3-noisettes.s2", "text": "noisettes. Il en a", "voice": "denise" },
    { "id": "bsc.t3-noisettes.s3", "text": "de moins que Plume.", "voice": "denise" },
    { "id": "bsc.t3-noisettes.q", "text": "Combien de noisettes a Plume ?", "voice": "denise" },
    { "id": "bsc.t3-noisettes.r1", "text": "Plume a", "voice": "denise" },
    { "id": "bsc.t3-noisettes.r2", "text": "noisettes !", "voice": "denise" }
  ]
}
