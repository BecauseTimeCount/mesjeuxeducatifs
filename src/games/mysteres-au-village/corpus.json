{
  "voice-default": "denise",
  "entries": [
    { "id": "mav.intro", "text": "Bienvenue au village des mystères ! Écoute bien les histoires et les indices, puis démasque le bon personnage. Choisis ton niveau, puis appuie sur Jouer !", "voice": "eloise" },
    { "id": "mav.niveau.0", "text": "L'étiquette mystère : pose l'étiquette dorée sur le bon personnage !", "voice": "eloise" },
    { "id": "mav.niveau.1", "text": "Les étiquettes malines : attention, ils sont parfois plusieurs !", "voice": "eloise" },
    { "id": "mav.niveau.2", "text": "L'enquête : écoute les indices et trouve le coupable !", "voice": "eloise" },
    { "id": "mav.niveau.3", "text": "La grande enquête : des indices de vrai détective !", "voice": "eloise" },
    { "id": "mav.qui", "text": "De qui parle-t-on ? Prends l'étiquette dorée, puis pose-la sur le bon personnage !", "voice": "denise" },
    { "id": "mav.prends", "text": "Tape d'abord sur l'étiquette dorée, puis sur le personnage !", "voice": "eloise" },
    { "id": "mav.trouve", "text": "Bravo, détective ! Mystère résolu !", "voice": "henri" },
    { "id": "mav.hint.etiquette", "text": "Regarde les badges : un ou plusieurs ? Fille ou garçon ? L'étiquette te dit tout !", "voice": "eloise" },
    { "id": "mav.hint.enquete", "text": "Les personnages tout gris ne correspondent plus aux indices. Le coupable est parmi les autres !", "voice": "eloise" },
    { "id": "mav.oups.genre.m", "text": "Moi ? Mais je suis un garçon !", "voice": "henri" },
    { "id": "mav.oups.genre.f", "text": "Moi ? Mais je suis une fille !", "voice": "eloise" },
    { "id": "mav.oups.nombre.pl", "text": "Nous ? Mais nous sommes plusieurs !", "voice": "eloise" },
    { "id": "mav.oups.nombre.sg", "text": "Moi ? Mais je suis tout seul !", "voice": "henri" },
    { "id": "mav.oups.sens", "text": "Écoute bien la fin de l'histoire... Qui peut vraiment faire ça ?", "voice": "denise" },
    { "id": "mav.enquete.intro", "text": "Alerte au village ! Une enquête commence !", "voice": "henri" },
    { "id": "mav.enquete.ecarte", "text": "Si un personnage ne correspond pas à l'indice, tape dessus pour l'écarter !", "voice": "henri" },
    { "id": "mav.enquete.designe", "text": "C'était le dernier indice ! Tape sur le coupable !", "voice": "henri" },
    { "id": "mav.indice.1", "text": "Premier indice !", "voice": "henri" },
    { "id": "mav.indice.2", "text": "Deuxième indice !", "voice": "henri" },
    { "id": "mav.indice.3", "text": "Dernier indice !", "voice": "henri" },
    { "id": "mav.pardon", "text": "Ce n'est pas moi ! Je m'en vais... pardon, pardon !", "voice": "eloise" },
    { "id": "mav.pas-lui", "text": "Attends ! Ce personnage correspond encore aux indices. Écoute bien !", "voice": "henri" },
    { "id": "mav.coupable", "text": "C'était moi, pardon ! Promis, je ne le ferai plus !", "voice": "eloise" },
    { "id": "mav.mefait.tarte", "text": "Quelqu'un a mangé la tarte du concours ! Mais qui ?", "voice": "denise" },
    { "id": "mav.mefait.cles", "text": "Quelqu'un a caché les clés de la mairie ! Mais qui ?", "voice": "denise" },
    { "id": "mav.mefait.peinture", "text": "Quelqu'un a renversé le pot de peinture ! Mais qui ?", "voice": "denise" },
    { "id": "mav.mefait.linge", "text": "Quelqu'un a fait tomber le linge tout propre ! Mais qui ?", "voice": "denise" },
    { "id": "mav.p.boulanger", "text": "Le boulanger", "voice": "denise" },
    { "id": "mav.p.fermiere", "text": "La fermière", "voice": "denise" },
    { "id": "mav.p.fermier", "text": "Le fermier", "voice": "denise" },
    { "id": "mav.p.grand-mere", "text": "La grand-mère", "voice": "denise" },
    { "id": "mav.p.grand-pere", "text": "Le grand-père", "voice": "denise" },
    { "id": "mav.p.maitresse", "text": "La maîtresse", "voice": "denise" },
    { "id": "mav.p.jumelles", "text": "Les jumelles", "voice": "denise" },
    { "id": "mav.p.jumeaux", "text": "Les jumeaux", "voice": "denise" },
    { "id": "mav.p.chien", "text": "Le chien", "voice": "denise" },
    { "id": "mav.p.chat", "text": "Le chat", "voice": "denise" },
    { "id": "mav.p.chats", "text": "Les chats", "voice": "denise" },
    { "id": "mav.p.poules", "text": "Les poules", "voice": "denise" },
    { "id": "mav.p.chevre", "text": "La chèvre", "voice": "denise" },
    { "id": "mav.pr.il", "text": "Il", "voice": "denise" },
    { "id": "mav.pr.elle", "text": "Elle", "voice": "denise" },
    { "id": "mav.pr.ils", "text": "Ils", "voice": "denise" },
    { "id": "mav.pr.elles", "text": "Elles", "voice": "denise" },
    { "id": "mav.a.tarte.sg", "text": "prépare une tarte.", "voice": "denise" },
    { "id": "mav.a.tarte.pl", "text": "préparent une tarte.", "voice": "denise" },
    { "id": "mav.s.tarte.sg", "text": "met des pommes dedans.", "voice": "denise" },
    { "id": "mav.s.tarte.pl", "text": "mettent des pommes dedans.", "voice": "denise" },
    { "id": "mav.a.fleurs.sg", "text": "arrose les fleurs.", "voice": "denise" },
    { "id": "mav.a.fleurs.pl", "text": "arrosent les fleurs.", "voice": "denise" },
    { "id": "mav.s.fleurs.sg", "text": "chante une jolie chanson.", "voice": "denise" },
    { "id": "mav.s.fleurs.pl", "text": "chantent une jolie chanson.", "voice": "denise" },
    { "id": "mav.a.velo.sg", "text": "fait du vélo.", "voice": "denise" },
    { "id": "mav.a.velo.pl", "text": "font du vélo.", "voice": "denise" },
    { "id": "mav.s.velo.sg", "text": "pédale très vite.", "voice": "denise" },
    { "id": "mav.s.velo.pl", "text": "pédalent très vite.", "voice": "denise" },
    { "id": "mav.v.poules", "text": "nourrit les poules.", "voice": "denise" },
    { "id": "mav.v.chien", "text": "promène le chien.", "voice": "denise" },
    { "id": "mav.v.chats", "text": "caresse les chats.", "voice": "denise" },
    { "id": "mav.v.chevre", "text": "brosse la chèvre.", "voice": "denise" },
    { "id": "mav.so.poules", "text": "picorent le grain.", "voice": "denise" },
    { "id": "mav.so.chien", "text": "remue la queue.", "voice": "denise" },
    { "id": "mav.so.chats", "text": "ronronnent doucement.", "voice": "denise" },
    { "id": "mav.so.chevre", "text": "fait bêê très fort.", "voice": "denise" },
    { "id": "mav.s.rentre.sg", "text": "rentre à la maison.", "voice": "denise" },
    { "id": "mav.i.quatre-pattes", "text": "Le coupable a quatre pattes !", "voice": "henri" },
    { "id": "mav.j.quatre-pattes", "text": "Le coupable ne marche pas sur deux jambes comme nous !", "voice": "henri" },
    { "id": "mav.i.moustaches", "text": "Le coupable a des moustaches !", "voice": "henri" },
    { "id": "mav.j.moustaches", "text": "On a trouvé un petit poil de moustache sur place !", "voice": "henri" },
    { "id": "mav.i.aime-les-os", "text": "Le coupable adore les os !", "voice": "henri" },
    { "id": "mav.j.aime-les-os", "text": "Le coupable a enterré quelque chose dans le jardin... un os !", "voice": "henri" },
    { "id": "mav.i.gourmand", "text": "Le coupable est très gourmand !", "voice": "henri" },
    { "id": "mav.j.gourmand", "text": "Le coupable se lèche encore les babines !", "voice": "henri" },
    { "id": "mav.i.chapeau", "text": "Le coupable porte un chapeau !", "voice": "henri" },
    { "id": "mav.j.chapeau", "text": "Avec ce grand soleil, le coupable n'a jamais chaud à la tête !", "voice": "henri" },
    { "id": "mav.i.lunettes", "text": "Le coupable porte des lunettes !", "voice": "henri" },
    { "id": "mav.j.lunettes", "text": "Le coupable a deux petits ronds de verre devant les yeux !", "voice": "henri" },
    { "id": "mav.i.tablier", "text": "Le coupable porte un tablier !", "voice": "henri" },
    { "id": "mav.j.tablier", "text": "Le coupable s'essuie toujours les mains sur son ventre !", "voice": "henri" },
    { "id": "mav.i.plumes", "text": "Le coupable a des plumes !", "voice": "henri" },
    { "id": "mav.j.plumes", "text": "On a trouvé une petite plume toute douce par terre !", "voice": "henri" },
    { "id": "mav.i.farine", "text": "Le coupable a de la farine sur les mains !", "voice": "henri" },
    { "id": "mav.j.farine", "text": "On a vu des petites traces blanches partout !", "voice": "henri" },
    { "id": "mav.i.tricot", "text": "Le coupable sait tricoter !", "voice": "henri" },
    { "id": "mav.j.tricot", "text": "On a trouvé un long fil de laine qui traîne !", "voice": "henri" },
    { "id": "mav.i.miaule", "text": "Le coupable sait miauler !", "voice": "henri" },
    { "id": "mav.j.miaule", "text": "On a entendu un petit miaou dans la nuit !", "voice": "henri" },
    { "id": "mav.i.jardin", "text": "Le coupable était dans le jardin ce matin !", "voice": "henri" },
    { "id": "mav.j.jardin", "text": "Le coupable a les pieds tout mouillés de rosée !", "voice": "henri" }
  ]
}
