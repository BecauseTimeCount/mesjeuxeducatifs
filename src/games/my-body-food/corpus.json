{
  "voice-default": "denise",
  "entries": [
    {
      "id": "mbf.intro",
      "text": "Bienvenue sur l'île d'ailleurs ! Ici, on joue en anglais. Écoute bien le mot, puis tape la bonne image. Choisis ton niveau, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "mbf.consigne.body",
      "text": "Écoute le mot en anglais, puis tape la bonne partie du corps !",
      "voice": "denise"
    },
    {
      "id": "mbf.consigne.food",
      "text": "Écoute le mot en anglais, puis tape le bon aliment !",
      "voice": "denise"
    },
    {
      "id": "mbf.consigne.tastes",
      "text": "Écoute : aime-t-il cet aliment, ou pas ? Range-le dans le bon panier !",
      "voice": "denise"
    },
    {
      "id": "mbf.niveau.0",
      "text": "Le corps en anglais : Head, Shoulders, Knees and Toes !",
      "voice": "eloise"
    },
    {
      "id": "mbf.niveau.1",
      "text": "Encore plus de parties du corps en anglais !",
      "voice": "eloise"
    },
    {
      "id": "mbf.niveau.2",
      "text": "Les aliments en anglais : à table !",
      "voice": "eloise"
    },
    {
      "id": "mbf.niveau.3",
      "text": "Les goûts : j'aime, ou je n'aime pas !",
      "voice": "eloise"
    },
    {
      "id": "mbf.bravo",
      "text": "Bravo ! Yes, c'est ça !",
      "voice": "eloise"
    },
    {
      "id": "mbf.bien-range",
      "text": "Bravo, bien rangé !",
      "voice": "eloise"
    },
    {
      "id": "mbf.thatone",
      "text": "Presque ! Ça, c'était :",
      "voice": "denise"
    },
    {
      "id": "mbf.pas-panier",
      "text": "Oups, ce n'est pas le bon panier. Écoute encore la phrase !",
      "voice": "denise"
    },
    {
      "id": "mbf.indice.tap",
      "text": "Regarde ! La bonne image brille pour t'aider.",
      "voice": "eloise"
    },
    {
      "id": "mbf.indice.sort",
      "text": "Regarde ! Le bon panier brille pour t'aider.",
      "voice": "eloise"
    },
