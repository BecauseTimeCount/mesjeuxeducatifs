{
  "voice-default": "denise",
  "entries": [
    {
      "id": "mds.intro",
      "text": "Bienvenue dans les mots de la semaine ! Choisis une famille de mots, explore l'imagier pour écouter chaque mot, puis viens jouer !",
      "voice": "eloise"
    },
    {
      "id": "mds.imagier",
      "text": "Tape sur chaque image pour écouter son mot. Quand tu les connais tous, appuie sur : je suis prêt à jouer !",
      "voice": "eloise"
    },
    {
      "id": "mds.pret",
      "text": "Bravo, tu as écouté tous les mots ! Appuie sur : je suis prêt à jouer !",
      "voice": "eloise"
    },
    {
      "id": "mds.trouve",
      "text": "Trouve...",
      "voice": "denise"
    },
    {
      "id": "mds.ca-cest",
      "text": "Ça, c'est...",
      "voice": "denise"
    },
    {
      "id": "mds.bien-joue",
      "text": "Oui ! Tu as attrapé le bon mot !",
      "voice": "eloise"
    },
    {
      "id": "mds.indice",
      "text": "Regarde bien : la bonne image se balance doucement !",
      "voice": "eloise"
    },
    {
      "id": "mds.familles.intro",
      "text": "Range les familles ! Écoute chaque mot, puis tape sur le panier de sa famille.",
      "voice": "eloise"
    },
    {
      "id": "mds.va-dans",
      "text": "Ce mot va dans la famille...",
      "voice": "denise"
    },
    {
      "id": "mds.panier-indice",
      "text": "Regarde le panier qui se balance !",
      "voice": "eloise"
    },
    {
      "id": "mds.bien-range",
      "text": "Bien rangé !",
      "voice": "eloise"
    },
