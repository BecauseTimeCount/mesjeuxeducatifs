{
  "voice-default": "denise",
  "entries": [
    {
      "id": "ptm.intro.accueil",
      "text": "Bienvenue dans ta boutique ! Les clients font la queue. Choisis ton niveau, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "ptm.intro.t0",
      "text": "Regarde bien le prix sur l'étiquette. Pose les pièces sur le plateau, puis appuie sur Encaisser !",
      "voice": "denise"
    },
    {
      "id": "ptm.intro.t1",
      "text": "Maintenant, le total du plateau est caché ! Compte les pièces dans ta tête, puis encaisse.",
      "voice": "denise"
    },
    {
      "id": "ptm.intro.t2",
      "text": "Le client te donne un billet. À toi de lui rendre la monnaie avec les pièces de la caisse !",
      "voice": "denise"
    },
    {
      "id": "ptm.intro.t3",
      "text": "Le client veut deux articles ! Additionne les deux prix dans ta tête, puis fais payer le total.",
      "voice": "denise"
    },
    { "id": "ptm.ca-fait", "text": "Ça fait...", "voice": "denise" },
    { "id": "ptm.coute", "text": "L'article coûte...", "voice": "denise" },
    { "id": "ptm.rends", "text": "Rends-lui la monnaie !", "voice": "denise" },
