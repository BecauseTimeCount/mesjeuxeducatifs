{
  "voice-default": "denise",
  "entries": [
    {
      "id": "tdm.intro",
      "text": "Bienvenue dans le tour du monde ! Trouve les paysages, puis range les éléments de la Terre. Choisis ton niveau, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "tdm.consigne.find",
      "text": "Écoute, puis trouve le bon paysage !",
      "voice": "denise"
    },
    {
      "id": "tdm.consigne.find.prefix",
      "text": "Trouve",
      "voice": "denise"
    },
    {
      "id": "tdm.consigne.sort",
      "text": "Range cet élément : est-ce de la terre, ou de l'eau ?",
      "voice": "denise"
    },
    {
      "id": "tdm.bravo",
      "text": "Bravo ! Bien trouvé !",
      "voice": "eloise"
    },
    {
