{
  "voice-default": "denise",
  "entries": [
    {
      "id": "chl.intro",
      "text": "Bienvenue à la chasse aux lettres ! Écoute bien la lettre que je te dis, puis attrape-la dans la scène. Choisis ton niveau, puis appuie sur Jouer !",
      "voice": "eloise"
    },
    {
      "id": "chl.consigne.trouve",
      "text": "Trouve la lettre…",
      "voice": "denise"
    },
    {
      "id": "chl.consigne.trouve-tous",
      "text": "Trouve tous les…",
      "voice": "denise"
    },
    {
      "id": "chl.consigne.trois",
      "text": "Il y en a trois, en trois écritures différentes !",
      "voice": "denise"
    },
    {
      "id": "chl.consigne.ecoute",
      "text": "Écoute bien le mot…",
      "voice": "denise"
    },
    {
      "id": "chl.consigne.commence",
      "text": "Quelle lettre commence le mot…",
      "voice": "denise"
    },
    {
      "id": "chl.indice",
      "text": "Regarde ! Les autres lettres s’effacent… La lettre qui brille, c’est celle qu’on cherche !",
      "voice": "eloise"
    },
    {
      "id": "chl.bien-vu",
      "text": "Bien vu ! Cherche les autres écritures…",
      "voice": "eloise"
    },
    {
      "id": "chl.verrouille",
      "text": "Ce niveau est encore fermé. Gagne deux étoiles au niveau d’avant pour l’ouvrir !",
      "voice": "denise"
    },
    {
      "id": "chl.niveau.0",
      "text": "Les capitales : les grandes lettres, comme sur les panneaux !",
      "voice": "eloise"
    },
    {
      "id": "chl.niveau.1",
      "text": "Les minuscules : les petites lettres, comme dans les livres !",
      "voice": "eloise"
    },
    {
      "id": "chl.niveau.2",
      "text": "Les trois écritures : attrape la même lettre trois fois !",
      "voice": "eloise"
    },
    {
      "id": "chl.niveau.3",
      "text": "Le premier son : trouve la lettre qui commence le mot !",
      "voice": "eloise"
    },
