    { "id": "chl.comme.a", "text": "A, comme avion !", "voice": "eloise" },
    { "id": "chl.comme.b", "text": "Bé, comme bateau !", "voice": "eloise" },
    { "id": "chl.comme.c", "text": "Cé, comme carotte !", "voice": "eloise" },
    { "id": "chl.comme.d", "text": "Dé, comme dauphin !", "voice": "eloise" },
    { "id": "chl.comme.e", "text": "E, comme éléphant !", "voice": "eloise" },
