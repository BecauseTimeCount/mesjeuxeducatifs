    { "id": "chl.comme.j", "text": "Ji, comme jus !", "voice": "eloise" },
    { "id": "chl.comme.k", "text": "Ka, comme kangourou !", "voice": "eloise" },
    { "id": "chl.comme.l", "text": "Elle, comme lune !", "voice": "eloise" },
    { "id": "chl.comme.m", "text": "Ème, comme maison !", "voice": "eloise" },
    { "id": "chl.comme.n", "text": "Ène, comme nuage !", "voice": "eloise" },
    { "id": "chl.comme.o", "text": "O, comme orange !", "voice": "eloise" },
    { "id": "chl.comme.p", "text": "Pé, comme papillon !", "voice": "eloise" },
    { "id": "chl.comme.q", "text": "Ku, comme quille !", "voice": "eloise" },
    { "id": "chl.comme.r", "text": "Erre, comme robot !", "voice": "eloise" },
    { "id": "chl.comme.s", "text": "Esse, comme soleil !", "voice": "eloise" },
    { "id": "chl.comme.t", "text": "Té, comme tortue !", "voice": "eloise" },
    { "id": "chl.comme.u", "text": "U, comme usine !", "voice": "eloise" },
    { "id": "chl.comme.v", "text": "Vé, comme vélo !", "voice": "eloise" },
    { "id": "chl.comme.w", "text": "Double vé, comme wagon !", "voice": "eloise" },
    { "id": "chl.comme.x", "text": "Ixe, comme xylophone !", "voice": "eloise" },
    { "id": "chl.comme.y", "text": "I grec, comme yoyo !", "voice": "eloise" },
    { "id": "chl.comme.z", "text": "Zède, comme zèbre !", "voice": "eloise" },
