{
  "voice-default": "denise",
  "entries": [
    {
      "id": "ui.bravo",
      "text": "Bravo !",
      "voice": "eloise"
    },
    {
      "id": "ui.super",
      "text": "Super, tu as réussi !",
      "voice": "eloise"
    },
    {
      "id": "ui.champion",
      "text": "Tu es un champion !",
      "voice": "eloise"
    },
    {
      "id": "ui.essaie-encore",
      "text": "Presque ! Essaie encore.",
      "voice": "eloise"
    },
    {
      "id": "ui.regarde-bien",
      "text": "Regarde bien, je te montre.",
      "voice": "eloise"
    },
    {
      "id": "ui.a-toi",
      "text": "À toi de jouer !",
      "voice": "eloise"
    },
    {
      "id": "ui.ecoute-bien",
      "text": "Écoute bien !",
      "voice": "eloise"
    },
    {
      "id": "ui.fin-session",
      "text": "Quelle aventure ! On a bien joué. Et si on faisait une pause ? L'archipel sera toujours là demain !",
      "voice": "eloise"
    },
    {
      "id": "ui.bienvenue",
      "text": "Bienvenue dans l'archipel ! Choisis une île et un jeu.",
      "voice": "eloise"
    },
    {
      "id": "ui.niveau-termine",
      "text": "Niveau terminé, félicitations !",
      "voice": "eloise"
    },
    {
      "id": "ui.nouveau-niveau",
      "text": "Tu as débloqué un nouveau niveau !",
      "voice": "eloise"
    },
    {
      "id": "ui.parcours",
      "text": "Voici tes défis du jour ! Tu peux aussi jouer à tout ce que tu veux.",
      "voice": "eloise"
    },
